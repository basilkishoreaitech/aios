# Azure OpenAI
AZURE_OPENAI_API_KEY=replace-with-openai-key
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_PRIMARY=gpt-5.4
AZURE_OPENAI_DEPLOYMENT_FALLBACK=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT_UTILITY=gpt-5.4-mini
AZURE_OPENAI_DEPLOYMENT_CRITIC=gpt-4.1
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Foundry IQ via Azure AI Search knowledge base
KB_PROVIDER=foundry_iq
FOUNDRY_IQ_ENDPOINT=https://your-search-service.search.windows.net
FOUNDRY_IQ_KEY=replace-with-search-admin-key
FOUNDRY_IQ_API_VERSION=2024-07-01
FOUNDRY_IQ_INDEX_NAME=aios-kb

# Optional Bing Search fallback
WEB_SEARCH_PROVIDER=auto
TAVILY_API_KEY=
TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Database
DATABASE_URL=postgresql+asyncpg://aios_admin:replace-with-password@your-postgres-server.postgres.database.azure.com:5432/aiosdev?ssl=require

# Auth
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Teams Integration (Optional)
TEAMS_WEBHOOK_URL=
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_SECRET=

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
ALLOWED_ORIGIN=http://localhost:8000
REQUIRE_LIVE_MODELS=true
REQUIRE_LIVE_WEB_SEARCH=false
ENABLE_SEED_SAMPLE_DATA=false
